# CryptoEmperor AI 环境变量配置模板
# 复制此文件为 .env 并填入真实值

# Binance API 配置（必填）
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here
BINANCE_BASE_URL=https://api.binance.com

# Telegram Bot 配置（可选，用于推送通知）
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 6551 API 配置（可选，用于新闻和 Twitter 情绪分析）
OPENNEWS_TOKEN=your_6551_token_here
TWITTER_TOKEN=your_6551_token_here

# 注意事项：
# 1. 建议使用只读 API Key（不要开启提现/交易权限）
# 2. 不要将 .env 文件提交到 Git 仓库
# 3. 如需测试网，将 BINANCE_BASE_URL 改为 https://testnet.binance.vision
# 4. Telegram Bot Token 从 @BotFather 获取
# 5. Chat ID 可通过 @userinfobot 获取
# 6. 6551 API Token 从 https://6551.io/mcp 获取（同一个 Token 用于新闻和 Twitter）
