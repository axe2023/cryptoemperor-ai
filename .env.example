# CryptoEmperor AI 环境变量配置模板
# 复制此文件为 .env 并填入真实值

# Binance API 配置（必填）
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here
BINANCE_BASE_URL=https://api.binance.com

# 注意事项：
# 1. 建议使用只读 API Key（不要开启提现/交易权限）
# 2. 不要将 .env 文件提交到 Git 仓库
# 3. 如需测试��，将 BINANCE_BASE_URL 改为 https://testnet.binance.vision
